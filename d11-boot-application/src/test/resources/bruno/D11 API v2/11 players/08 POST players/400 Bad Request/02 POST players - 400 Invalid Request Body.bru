meta {
  name: POST players - 400 Invalid Request Body
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/v2/players
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:json {
  {
      "player": {
  
      }
  }
}

assert {
  res.status: eq 400
  res.body.error: eq Bad Request
  res.body.method: eq POST
  res.body.path: eq /v2/players
  res.body.validationErrors: isDefined
  res.body.validationErrors.length: eq 6
  res.body.validationErrors[0].property: eq player.countryId
  res.body.validationErrors[0].error: eq is missing
  res.body.validationErrors[1].property: eq player.firstName
  res.body.validationErrors[1].error: eq is missing
  res.body.validationErrors[2].property: eq player.height
  res.body.validationErrors[2].error: eq is missing
  res.body.validationErrors[3].property: eq player.lastName
  res.body.validationErrors[3].error: eq is missing
  res.body.validationErrors[4].property: eq player.premierLeagueId
  res.body.validationErrors[4].error: eq is missing
  res.body.validationErrors[5].property: eq player.statSourceId
  res.body.validationErrors[5].error: eq is missing
}
