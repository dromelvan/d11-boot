meta {
  name: PUT transfer-windows/{transferWindowId} - 403
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/v2/transfer-windows/{{transferWindowId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:json {
  {
      "transferWindow": {{updatedTransferWindow}}
  }
}

assert {
  res.status: eq 403
}
