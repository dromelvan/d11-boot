meta {
  name: Setup - Update status
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/v2/transfer-windows/{{transferWindowId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:json {
  {
      "transferWindow": {{pendingTransferWindow}}
  }
}

assert {
  res.status: eq 200
  res.body.transferWindow: isDefined
  res.body.transferWindow.id: eq {{transferWindowId}}
  res.body.transferWindow.status: eq PENDING
}
