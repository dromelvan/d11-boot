meta {
  name: Rollback - Update status
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/v2/transfer-windows/{{transferWindowId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:json {
  {
      "transferWindow": {{finishedTransferWindow}}
  }
}

assert {
  res.status: eq 200
  res.body.transferWindow: isDefined
  res.body.transferWindow.id: eq {{transferWindowId}}
  res.body.transferWindow.status: eq FINISHED
}
