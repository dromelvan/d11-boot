meta {
  name: GET player-season-stats?seasonId={seasonId}&page={page}&positionIds=1,2,3,4,5&sort=FORM - 200
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/v2/player-season-stats?seasonId={{seasonId}}&page=0&positionIds=1,2,3,4,5&sort=FORM
  body: none
  auth: none
}

params:query {
  seasonId: {{seasonId}}
  page: 0
  positionIds: 1,2,3,4,5
  sort: FORM
}

assert {
  res.status: eq 200
  res.body.page: eq 0
  res.body.totalPages: eq 1
  res.body.totalElements: eq 2
  res.body.playerSeasonStats: isDefined
  res.body.playerSeasonStats.length: eq 2
}

tests {
  const { expectToEq } = require('./d11.js');
  
  test("GET season player season stats response body", () => {
    const body = res.getBody();
    const playerSeasonStats = JSON.parse(bru.getEnvVar("seasonPlayerSeasonStatsForm"));
  
    for (let i = 0; i < playerSeasonStats.length; ++i) {
      expectToEq.playerSeasonStat(body.playerSeasonStats[i], playerSeasonStats[i]);
    }
  
  });
  
}
