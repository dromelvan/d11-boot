meta {
  name: GET d11-team-season-stats?d11TeamId={d11TeamId} - 400 Invalid D11 Team Id
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/v2/d11-team-season-stats?d11TeamId=invalid
  body: none
  auth: none
}

params:query {
  d11TeamId: invalid
  page: 0
}

assert {
  res.status: eq 400
  res.body.error: eq Bad Request
  res.body.method: eq GET
  res.body.path: eq /v2/d11-team-season-stats
  res.body.validationErrors.length: eq 1
  res.body.validationErrors[0].property: eq d11TeamId
  res.body.validationErrors[0].error: eq is invalid
}
