meta {
  name: GET d11-team-season-stats?seasonId={seasonId} - 400 Both Season Id and D11 Team Id
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/v2/d11-team-season-stats?seasonId={{seasonId}}&d11TeamId={{d11TeamId}}
  body: none
  auth: none
}

params:query {
  seasonId: {{seasonId}}
  d11TeamId: {{d11TeamId}}
}

assert {
  res.status: eq 400
  res.body.error: eq Bad Request
  res.body.method: eq GET
  res.body.path: eq /v2/d11-team-season-stats
  res.body.validationErrors.length: eq 1
  res.body.validationErrors[0].property: eq seasonId or d11TeamId
  res.body.validationErrors[0].error: eq one and only one must be provided
}
