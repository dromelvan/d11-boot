meta {
  name: GET transfer-bids?transferDayId={transferDayId}&playerId={playerId} - 400 Negative Player Id
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/v2/transfer-bids?transferDayId={{transferDayId}}&playerId=-1
  body: none
  auth: none
}

params:query {
  transferDayId: {{transferDayId}}
  playerId: -1
}

assert {
  res.status: eq 400
  res.body.error: eq Bad Request
  res.body.method: eq GET
  res.body.path: eq /v2/transfer-bids
  res.body.validationErrors.length: eq 1
  res.body.validationErrors[0].property: eq playerId
  res.body.validationErrors[0].error: eq must be positive
}
