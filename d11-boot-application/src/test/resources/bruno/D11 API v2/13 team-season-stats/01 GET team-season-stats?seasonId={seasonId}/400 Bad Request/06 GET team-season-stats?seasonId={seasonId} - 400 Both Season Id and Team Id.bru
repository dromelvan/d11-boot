meta {
  name: GET team-season-stats?seasonId={seasonId} - 400 Both Season Id and Team Id
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/v2/team-season-stats?seasonId={{seasonId}}&teamId={{teamId}}
  body: none
  auth: none
}

params:query {
  seasonId: {{seasonId}}
  teamId: {{teamId}}
}

assert {
  res.status: eq 400
  res.body.error: eq Bad Request
  res.body.method: eq GET
  res.body.path: eq /v2/team-season-stats
  res.body.validationErrors.length: eq 1
  res.body.validationErrors[0].property: eq seasonId or teamId
  res.body.validationErrors[0].error: eq one and only one must be provided
}
