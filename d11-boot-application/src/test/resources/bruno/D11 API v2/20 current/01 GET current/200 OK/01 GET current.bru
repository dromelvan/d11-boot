meta {
  name: 01 GET current
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/v2/current
  body: none
  auth: inherit
}

assert {
  res.status: eq 200
  res.body.season: isDefined
  res.body.matchWeek: isDefined
  res.body.transferWindow: isDefined
  res.body.transferDay: isDefined
}

tests {
  const { expectToEq } = require('./d11.js');
  
  test("GET current response body", () => {
    const body = res.getBody();
    const currentSeason = JSON.parse(bru.getEnvVar("currentSeason"));
    const currentMatchWeek = JSON.parse(bru.getEnvVar("currentMatchWeek"));
    const currentTransferWindow = JSON.parse(bru.getEnvVar("currentTransferWindow"));
    const currentTransferDay = JSON.parse(bru.getEnvVar("currentTransferDay"));
  
    expectToEq.seasonBase(body.season, currentSeason);
    expectToEq.matchWeekBase(body.matchWeek, currentMatchWeek);
    expectToEq.transferWindowBase(body.transferWindow, currentTransferWindow);
    expectToEq.transferDayBase(body.transferDay, currentTransferDay);
  });
  
}

settings {
  encodeUrl: true
  timeout: 0
}
